<?xml version="1.0" encoding="UTF-8"?>
<office:document
  xmlns:office="urn:oasis:names:tc:opendocument:xmlns:office:1.0"
  xmlns:text="urn:oasis:names:tc:opendocument:xmlns:text:1.0"
  xmlns:style="urn:oasis:names:tc:opendocument:xmlns:style:1.0"
  xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"
  office:mimetype="application/vnd.oasis.opendocument.text-flat-xml">
  <office:automatic-styles>
  <style:style style:name="Bold" style:family="text">
    <style:text-properties fo:font-weight="bold"/>
  </style:style>
  <style:style style:name="Italic" style:family="text">
    <style:text-properties fo:font-style="italic"/>
  </style:style>
</office:automatic-styles>
<office:body>
  <office:text>
    <text:p>Normal text section.</text:p>
    <text:p><text:span text:style-name="Bold">Bold text section</text:span></text:p>
    <text:p><text:span text:style-name="Italic">Italic text section</text:span></text:p>
    <text:list>
      <text:list-item><text:p>First list item</text:p></text:list-item>
      <text:list-item><text:p>Second list item</text:p></text:list-item>
    </text:list>
  </office:text>
</office:body>
</office:document>