{
  "name": "document-markdown-reader",
  "version": "0.1.0",
  "description": "Browser-focused document reader that imports common file formats and returns Markdown.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf dist coverage",
    "build": "npm run clean && vite build && tsc -p tsconfig.build.json",
    "lint": "eslint . --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "document-reader",
    "document-import",
    "markdown",
    "html",
    "docx",
    "pdf"
  ],
  "author": {
    "name": "Interview Challenge Archive",
    "url": "https://interview-challenge-archive.github.io"
  },
  "dependencies": {
    "@freshgum/typedi": "^0.7.2",
    "@iarna/rtf-to-html": "^1.1.0",
    "@jose.espana/docstream": "^0.1.3",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "markdown-it": "^14.1.1",
    "pdfjs-dist": "^5.5.207",
    "reflect-metadata": "^0.2.2",
    "turndown": "^7.2.2",
    "turndown-plugin-gfm": "^1.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@swc/core": "^1.15.18",
    "@types/jsdom": "^28.0.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.5.0",
    "@types/turndown": "^5.0.6",
    "eslint": "^10.1.0",
    "jsdom": "^29.0.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "unplugin-swc": "^1.5.9",
    "vite": "^7.1.12",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24.0.0"
  }
}
