{
  "name": "@interview-challenge-archive/document-markdown-reader",
  "version": "0.3.2",
  "description": "Browser-focused document reader that imports common file formats and returns Markdown.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf dist coverage",
    "build": "npm run clean && vite build && tsc -p tsconfig.build.json",
    "lint": "eslint . --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e:examples": "playwright test test/e2e/examples/upload-text.spec.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "document-reader",
    "document-import",
    "markdown",
    "html",
    "docx",
    "pdf"
  ],
  "author": {
    "name": "Interview Challenge Archive",
    "url": "https://interview-challenge-archive.github.io"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Interview-Challenge-Archive/document-markdown-reader"
  },
  "homepage": "https://github.com/Interview-Challenge-Archive/document-markdown-reader",
  "dependencies": {
    "@freshgum/typedi": "^0.7.2",
    "iconv-lite": "^0.7.2",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "markdown-it": "^14.1.1",
    "node-html-parser": "^7.1.0",
    "odf-kit": "^0.13.1",
    "pdfjs-dist": "^5.5.207",
    "reflect-metadata": "^0.2.2",
    "rtf-stream-parser": "^3.8.1",
    "turndown": "^7.2.2",
    "turndown-plugin-gfm": "^1.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@rollup/plugin-inject": "^5.0.5",
    "@swc/core": "^1.15.18",
    "@types/jsdom": "^28.0.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.5.0",
    "@types/turndown": "^5.0.6",
    "buffer": "^6.0.3",
    "eslint": "^10.1.0",
    "events": "^3.3.0",
    "jsdom": "^29.0.1",
    "process": "^0.11.10",
    "rimraf": "^6.0.1",
    "stream-browserify": "^3.0.0",
    "string_decoder": "^1.3.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.1",
    "unplugin-swc": "^1.5.9",
    "util": "^0.12.5",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
