{
  "categories": [
    {
      "title": "🚀 Features",
      "labels": ["feature", "enhancement"]
    },
    {
      "title": "🐛 Bug Fixes",
      "labels": ["bug", "fix"]
    },
    {
      "title": "📝 Documentation",
      "labels": ["documentation", "docs"]
    },
    {
      "title": "🔧 Maintenance",
      "labels": ["chore", "maintenance", "dependencies"]
    },
    {
      "title": "📦 Other Changes",
      "labels": []
    }
  ],
  "ignore_labels": ["skip-changelog", "no-release"],
  "sort": {
    "order": "ASC"
  },
  "base_branches": ["main"],
  "pr_template": "- #${{NUMBER}} ${{TITLE}} (@${{AUTHOR}})",
  "empty_template": "No changes."
}
