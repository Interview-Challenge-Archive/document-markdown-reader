# Examples

This folder contains complete working examples demonstrating how to use `document-markdown-reader` in various environments.

Each example includes:
- A `README.md` with setup instructions
- A `package.json` with all required dependencies
- Source files showing the library in action

## Directory Structure

Examples are organized by language, framework, and build tool:
- `{language}/{framework}/{build-tool}`

<%
const buildToolLinks = {
  vite: 'https://vitejs.dev/',
  webpack: 'https://webpack.js.org/',
  parcel: 'https://parceljs.org/',
  rollup: 'https://rollupjs.org/',
  rspack: 'https://rspack.dev/',
  turbopack: 'https://turbo.build/pack'
};

const buildToolNames = {
  vite: 'Vite',
  webpack: 'Webpack',
  parcel: 'Parcel',
  rollup: 'Rollup',
  rspack: 'Rspack',
  turbopack: 'Turbopack'
};

const frameworkNames = {
  vanilla: 'Vanilla (No Framework)',
  react: 'React',
  vue: 'Vue',
  svelte: 'Svelte',
  solidjs: 'SolidJS'
};

const languageNames = {
  javascript: 'JavaScript',
  typescript: 'TypeScript'
};

const languageOrder = ['javascript', 'typescript'];
const frameworkOrder = ['vanilla', 'react', 'vue', 'svelte', 'solidjs'];
const buildToolOrder = ['vite', 'webpack', 'rspack', 'turbopack', 'parcel', 'rollup'];

const repo = inputs.github_repo || '';
const folders = inputs.folders || [];

const examplesTree = {};
folders.forEach((folder) => {
  const parts = folder.replace(/^examples\//, '').split('/');
  if (parts.length !== 3) {
    return;
  }

  const language = parts[0];
  const framework = parts[1];
  const buildTool = parts[2];

  if (!examplesTree[language]) {
    examplesTree[language] = {};
  }

  if (!examplesTree[language][framework]) {
    examplesTree[language][framework] = [];
  }

  if (!examplesTree[language][framework].includes(buildTool)) {
    examplesTree[language][framework].push(buildTool);
  }
});

function sortByOrder(values, order) {
  return values.slice().sort((a, b) => {
    const aIndex = order.indexOf(a);
    const bIndex = order.indexOf(b);

    if (aIndex === -1 && bIndex === -1) {
      return a.localeCompare(b);
    }

    if (aIndex === -1) {
      return 1;
    }

    if (bIndex === -1) {
      return -1;
    }

    return aIndex - bIndex;
  });
}

const languages = sortByOrder(Object.keys(examplesTree), languageOrder);
